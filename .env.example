# Supabase 환경변수
# https://supabase.com 에서 프로젝트 생성 후 다음 정보를 입력하세요

# 프로젝트 API URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# 공개 Anon Key (클라이언트 측에서 사용 가능)
VITE_SUPABASE_ANON_KEY=your_public_anon_key_here

# 선택: 일별 메트릭 테이블명 (미설정 시 dashboard_data — docs/domain 기준)
# 다른 이름(예: daily_metrics)만 있을 때만 지정:
# VITE_SUPABASE_METRICS_TABLE=daily_metrics
